# ── ZimKAG webapp endpoint ────────────────────────────────────────────────
# The webapp must be running (run.bat in zimkag_webapp/) before starting the watcher.
ZIMKAG_URL=http://127.0.0.1:18000
ZIMKAG_TIMEOUT=300
ZIMKAG_USE_LLM=true

# ── Polling behaviour ──────────────────────────────────────────────────────
POLL_INTERVAL_SEC=30        # seconds between Gmail polls
MAX_MESSAGES_PER_POLL=10    # cap per poll to be polite to the API
MAX_ATTACHMENT_MB=25        # ignore attachments larger than this
LOOKBACK_DAYS=1             # only consider messages from the last N days

# ── Contract detection ─────────────────────────────────────────────────────
# Minimum number of distinct construction-contract keywords in an attachment
# for it to be classified as a contract worth analysing.
MIN_KEYWORD_HITS=3

# ── Gmail labels ───────────────────────────────────────────────────────────
LABEL_PROCESSED=ZimKAG/Processed
LABEL_SKIPPED=ZimKAG/Skipped

# ── Reply behaviour ────────────────────────────────────────────────────────
# false (default) → the report email is sent to your own inbox (best for trust
#                   verification + thesis demo).
# true  → reply directly to the original sender. Only flip this once you've
#         tested the system end-to-end and trust the output.
REPLY_TO_SENDER=false

# Set to true to skip actually sending the email (analysis still runs, useful
# for testing).
DRY_RUN=false

# ── Logging ────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR
