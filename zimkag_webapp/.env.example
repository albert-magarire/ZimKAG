# --- Required for LLM-powered clause rewrites ---
# Get a free key at https://console.groq.com/keys
GROQ_API_KEY=your_groq_key_here

# Model used for rewrites (Groq-hosted)
GROQ_MODEL=llama-3.3-70b-versatile

# --- Model & app config ---
MODEL_DIR=./models/zimkag_legalbert_5class
HOST=127.0.0.1
PORT=8000

# Set to 1 to allow inference without a trained model (LLM + KG only fallback)
ALLOW_NO_MODEL=0
